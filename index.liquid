---
layout: layout.liquid
title: The Name Generator 
---
<div x-data="{
    names: ['Colin', 'DeAndre', 'Gabe', 'Devin', 'Angelo', 'AJ', 'Zach', 'Connor', 'Luke', 'Malachi'],
    current: 'Click Right Here!!'
}">

<h1 class="text-6x1 font-bold mb-6">The Name Generator!</h1>

<h2 class="text-3xl mb-6" x-text="current"></h2>

 <button
    @click="current = names[Math.round(Math.random() * (names.length - 1))]"
    class="bg-cyan-400 text-gray-800 font-bold px-6 py-2 rounded"
  >
    Random Name
  </button>

</div>